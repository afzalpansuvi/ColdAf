{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend API",
      "runtimeExecutable": "C:/Program Files/nodejs/node.exe",
      "runtimeArgs": ["src/index.js"],
      "port": 4000,
      "cwd": "backend"
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "C:/Program Files/nodejs/node.exe",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "3000"],
      "port": 3000,
      "cwd": "frontend"
    }
  ]
}
