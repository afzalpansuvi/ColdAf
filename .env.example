# ===========================================
# ColdAF Email Tool - Environment Variables
# ===========================================

# Database
DATABASE_URL=postgresql://coldaf:coldaf_password@postgres:5432/coldaf_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=coldaf_db
DB_USER=coldaf
DB_PASSWORD=coldaf_password

# Redis
REDIS_URL=redis://redis:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# Encryption (AES-256 key - must be 32 bytes hex encoded)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# AI Providers (set via .env or manage from Dashboard > Integrations > API Keys)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Server
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://coldaf.ataflexsolutions.com
BACKEND_URL=https://coldaf.ataflexsolutions.com

# Initial Admin Account (used by seed script)
ADMIN_EMAIL=admin@coldaf.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_NAME=System Admin

# SendGrid (optional)
SENDGRID_API_KEY=

# Mailgun (optional)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Google Sheets Service Account (JSON key file path)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# Upload directory
UPLOAD_DIR=./uploads

# Vapi.ai — Phone Call Agent
VAPI_API_KEY=                   # Your Vapi private key (from dashboard.vapi.ai)
VAPI_PHONE_NUMBER_ID=           # ID of the phone number to call from (create in Vapi dashboard)
VAPI_ASSISTANT_ID=              # ID of the assistant to use for calls (create in Vapi dashboard)
VAPI_WEBHOOK_SECRET=            # Secret for verifying Vapi webhook payloads

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_AGENCY=

# Gmail OAuth (required for Gmail sending feature)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://yourdomain.com/api/gmail/oauth/callback

# Platform owner (admin panel access)
PLATFORM_OWNER_EMAIL=apansuvi1@gmail.com

# Deployment domain (used in docker-compose.prod.yml Traefik labels)
DOMAIN=coldaf.ataflexsolutions.com

# Frontend env vars
VITE_PLATFORM_OWNER_EMAIL=apansuvi1@gmail.com
