# ===========================================
# ColdAF Email Tool - Production Environment
# ===========================================

# Database
DB_NAME=coldaf_db
DB_USER=coldaf
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_HERE
DATABASE_URL=postgresql://coldaf:CHANGE_ME_STRONG_DB_PASSWORD_HERE@postgres:5432/coldaf_db
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379

# JWT Authentication (CHANGE THESE - use: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHAR_HEX
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# Encryption (AES-256 key - use: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_RANDOM_64_CHAR_HEX

# AI Providers (set here OR manage from Dashboard > Integrations > API Keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Server
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://coldaf.ataflexsolutions.com
BACKEND_URL=https://coldaf.ataflexsolutions.com

# Initial Admin Account (used by seed script - CHANGE THE PASSWORD)
ADMIN_EMAIL=admin@coldaf.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_NAME=System Admin

# SendGrid (optional)
SENDGRID_API_KEY=

# Mailgun (optional)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Google Sheets Service Account (JSON key file path)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# Upload directory
UPLOAD_DIR=./uploads
